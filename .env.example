DEEPSEEK_API_KEY=your_deepseek_api_key_here
MONGODB_URI=mongodb://localhost:27017/wellness-tracker
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=promptwars:foundation:
PORT=3001
NODE_ENV=development
ALLOWED_ORIGIN=https://your-production-domain.example

# Rate limiting is off in development. Production default: 120 req/min per user.
# RATE_LIMIT_ENABLED=false
# RATE_LIMIT_PER_MINUTE=120

# Easypanel deployment: set these in the app Environment tab (no .env file in container).
# Use Easypanel internal service hostnames — not localhost.
# NODE_ENV=production
# ALLOWED_ORIGIN=https://your-production-domain.example
# PORT=80
# MONGODB_URI=mongodb://<mongo-service-host>:27017/wellness-tracker
# REDIS_URL=redis://<redis-service-host>:6379
